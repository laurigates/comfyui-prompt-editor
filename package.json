{
  "name": "comfyui-prompt-editor",
  "private": true,
  "type": "module",
  "description": "Full-screen touch editor for multiline prompt widgets. TypeScript source in src/, built to web/dist/ via bun build (inlining @laurigates/comfy-modal-kit). See ADR-0011.",
  "scripts": {
    "build": "bun build ./src/index.ts --target browser --format esm --outdir web/dist --external '/scripts/*'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "knip": "knip"
  },
  "dependencies": {
    "@laurigates/comfy-modal-kit": "^0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@comfyorg/comfyui-frontend-types": "^1.43.0",
    "@biomejs/biome": "^2.4.15",
    "vitest": "^4.1.7",
    "knip": "^5.0.0"
  }
}
